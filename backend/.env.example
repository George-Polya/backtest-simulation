# Natural Language Backtesting Service - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# LLM API Key
# ============================================
OPENROUTER_API_KEY=your_openrouter_api_key_here


# Docker socket URL (leave empty for auto-detect)
# macOS Docker Desktop: unix:///Users/<username>/.docker/run/docker.sock
# Linux / WSL2: unix:///var/run/docker.sock
DOCKER_SOCKET_URL=
