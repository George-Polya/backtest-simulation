# Frontend Environment Variables
# Copy this file to .env.local and adjust values as needed

# ============================================
# API Configuration
# ============================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ============================================
# Optional Settings
# ============================================
# Code generation timeout in milliseconds (default: 120000 = 2 minutes)
NEXT_PUBLIC_CODE_GENERATION_TIMEOUT_MS=1800000
